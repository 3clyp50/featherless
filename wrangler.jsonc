{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featherless-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "vars": {
    "SHARP_STRICT_CONTEXT": "0",
    "FEATHERLESS_DEV_MODE": "0",
    "MEM0_DISABLED": "1",
    "WRITE_BACK": "0",
    "LLM_MODEL": "@cf/openai/gpt-oss-120b"
  },
  "ai": { "binding": "AI" },
  "kv_namespaces": [
    {
      "binding": "RENDER_CACHE",
      "id": "5725f9a173644ca2b8131da09d7784b9",
      "preview_id": "6d34d97856e849e6a2d57c3875d4636c"
    }
  ]
}
